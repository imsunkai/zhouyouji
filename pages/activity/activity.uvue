])

const events = ref([
	{ avatar: '/static/zy/logo-mark.png', nickname: '舟山阿宁', time: '10分钟前', image: '/static/zy/car-coast.jpg', title: '明早普陀山码头接送，有车源推荐吗？', category: '找服务', typeClass: 'tag-blue', content: '2位成人，早上7点从东港出发到朱家尖码头，希望司机熟悉路线，价格透明。', likes: 18, comments: 6 },
