	{ avatar: '/static/logo.png', nickname: '沈家门老周', time: '2小时前', image: '/static/zy/harbor.jpg', title: '本地资源对接：码头周边停车和搬运', category: '本地交流', typeClass: 'tag-purple', content: '最近有朋友问码头附近停车和行李搬运资源，这里整理了一些经验，欢迎补充。', likes: 56, comments: 24 }
])

function selectCategory(idx: number) {
	activeCategory.value = idx
}

function showComing(name: string) {
	uni.showToast({
