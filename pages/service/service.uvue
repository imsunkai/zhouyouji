import { createCloudObject } from '/utils/cloud-object.js'
import { onLoad } from '@dcloudio/uni-app'

const serviceObj = createCloudObject('service')

const activeCategory = ref(0)

// TODO: 后续接服务聚合 API，按分类返回服务项、顾问信息和跳转配置。
