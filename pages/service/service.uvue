<template>
	<view class="page">
		<view class="service-layout">
			<scroll-view class="side-nav" scroll-y show-scrollbar="false">
				<view
					v-for="(item, idx) in serviceSections"
					:key="idx"
					:class="activeCategory == idx ? 'nav-item active' : 'nav-item'"
					@tap="selectCategory(idx)"
				>
					<view v-if="activeCategory == idx" class="nav-indicator"></view>
					<text class="nav-icon">{{item.icon}}</text>
					<text class="nav-text">{{item.shortTitle}}</text>
				</view>
			</scroll-view>

			<scroll-view class="content" scroll-y show-scrollbar="false">
				<view class="section-card" v-for="(section, sIdx) in serviceSections" :key="sIdx">
					<view class="section-head">
						<view class="title-row">
							<text class="section-title">{{section.title}}</text>
							<text class="section-sub">{{section.subtitle}}</text>
						</view>
						<text class="more" @tap="openRoute('/pages/service/detail', false)">查看更多 ›</text>
					</view>

					<view class="service-grid">
						<view class="service-item" v-for="(item, idx) in section.items" :key="idx" @tap="openRoute(item.url, item.tab)">
							<image class="service-image" :src="item.image" mode="aspectFill" />
							<text class="service-name">{{item.title}}</text>
							<text class="service-desc">{{item.desc}}</text>
						</view>
					</view>

					<view class="helper-card" :style="'background:' + section.helperBg">
						<view class="helper-icon" :style="'background:' + section.color">
							<text class="helper-symbol">{{section.icon}}</text>
						</view>
						<view class="helper-copy">
							<text class="helper-title">{{section.helperTitle}}</text>
							<text class="helper-desc">{{section.helperDesc}}</text>
						</view>
						<view class="helper-btn" :style="'background:' + section.color" @tap="openRoute(section.actionUrl, section.actionTab)">
							<text class="btn-text">{{section.actionText}}</text>
						</view>
					</view>
				</view>

				<view class="bottom-space"></view>
			</scroll-view>
		</view>
	</view>
</template>

