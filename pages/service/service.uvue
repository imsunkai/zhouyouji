	{
		shortTitle: '旅游服务',
		title: '旅游服务',
		subtitle: '玩转舟山 发现海岛之美',
		icon: '岛',
		color: '#1677FF',
		helperBg: '#edf5ff',
		helperTitle: '旅游顾问在线',
		helperDesc: '行程规划 · 景点推荐 · 预订咨询',
		actionText: '立即咨询',
		actionUrl: '/pages/service/detail',
		actionTab: false,
		items: [
			{ image: '/static/zy/route-island.jpg', title: '经典线路', desc: '热门线路推荐', url: '/pages/service/detail', tab: false },
			{ image: '/static/zy/yacht.jpg', title: '定制旅行', desc: '专属行程定制', url: '/pages/service/detail', tab: false },
			{ image: '/static/zy/harbor.jpg', title: '包船出海', desc: '游艇出海体验', url: '/pages/service/detail', tab: false },
			{ image: '/static/zy/tour-lighthouse.jpg', title: '导游服务', desc: '专业讲解服务', url: '/pages/service/detail', tab: false }
		]
	},
	{
		shortTitle: '车务服务',
		title: '车务服务',
		subtitle: '安全舒适 便捷出行',
		icon: '车',
		color: '#2F80ED',
		helperBg: '#edf5ff',
		helperTitle: '车辆调度中心',
		helperDesc: '多种车型可选 · 价格透明 · 服务保障',
		actionText: '立即预约',
		actionUrl: '/pages/service/detail',
		actionTab: false,
		items: [
			{ image: '/static/zy/car-coast.jpg', title: '接送服务', desc: '机场/码头/站点接送', url: '/pages/service/detail', tab: false },
			{ image: '/static/zy/car-coast.jpg', title: '包车服务', desc: '多种车型 包车出行', url: '/pages/service/detail', tab: false },
			{ image: '/static/zy/car-coast.jpg', title: '租车服务', desc: '自驾租车 灵活便捷', url: '/pages/service/detail', tab: false },
			{ image: '/static/zy/car-coast.jpg', title: '二手车交易', desc: '精品车源 专业评估', url: '/pages/car/index', tab: false }
		]
	},
	{
		shortTitle: '住宿资源',
		title: '住宿资源',
		subtitle: '精选好房 舒适入住',
		icon: '住',
		color: '#52C41A',
		helperBg: '#f0fbf3',
		helperTitle: '住宿顾问为您服务',
		helperDesc: '房源推荐 · 价格咨询 · 预订协助',
		actionText: '立即咨询',
		actionUrl: '/pages/service/detail',
		actionTab: false,
		items: [
			{ image: '/static/zy/hotel-room.jpg', title: '酒店推荐', desc: '品质酒店 安心入住', url: '/pages/service/detail', tab: false },
			{ image: '/static/zy/homestay.jpg', title: '民宿客栈', desc: '特色民宿 体验当地生活', url: '/pages/service/detail', tab: false },
			{ image: '/static/zy/hotel-seaview.jpg', title: '公寓短租', desc: '长租短租 灵活选择', url: '/pages/service/detail', tab: false }
		]
	},
	{
		shortTitle: '商城特产',
		title: '商城特产',
		subtitle: '本地好物 品质优选',
		icon: '购',
		color: '#FA8C16',
		helperBg: '#fff3e8',
		helperTitle: '精选好物 等你来选',
		helperDesc: '品质保证 · 产地直供 · 快递发货',
		actionText: '进入商城',
		actionUrl: '/pages/mall/mall',
		actionTab: false,
		items: [
			{ image: '/static/zy/crab.jpg', title: '海鲜水产', desc: '新鲜直达', url: '/pages/mall/mall', tab: false },
			{ image: '/static/zy/fish.jpg', title: '食品特产', desc: '地道美味', url: '/pages/mall/mall', tab: false },
			{ image: '/static/zy/mall-hero.jpg', title: '文创精品', desc: '岛城记忆', url: '/pages/mall/mall', tab: false },
			{ image: '/static/zy/abalone.jpg', title: '礼盒专区', desc: '送礼优选', url: '/pages/mall/mall', tab: false }
		]
	},
	{
		shortTitle: '二手车',
		title: '二手车服务',
		subtitle: '精品车源 专业交易',
		icon: '换',
		color: '#722ED1',
		helperBg: '#f5efff',
		helperTitle: '二手车顾问在线',
		helperDesc: '车源筛选 · 车辆评估 · 过户保险',
		actionText: '找车源',
		actionUrl: '/pages/car/index',
		actionTab: false,
		items: [
			{ image: '/static/zy/car-coast.jpg', title: '车辆买卖', desc: '本地车源 快速匹配', url: '/pages/car/index', tab: false },
			{ image: '/static/zy/car-coast.jpg', title: '精品车源', desc: '严选检测 透明车况', url: '/pages/car/list', tab: false },
			{ image: '/static/zy/car-coast.jpg', title: '车辆评估', desc: '专业估值 合理报价', url: '/pages/car/index', tab: false },
			{ image: '/static/zy/car-coast.jpg', title: '过户保险', desc: '代办服务 省心交付', url: '/pages/car/index', tab: false }
		]
	}
])

onLoad(() => {
	loadServiceSections()
})

async function loadServiceSections() {
	try {
		const categoryRes = await serviceObj.getCategoryList({})
		if (categoryRes.errCode != 0 || categoryRes.data.list.length == 0) return
		const sections = []
		for (let i = 0; i < categoryRes.data.list.length; i++) {
			const category = categoryRes.data.list[i]
			const listRes = await serviceObj.getListByCategory({
				categoryId: category._id,
				page: 1,
				pageSize: 8
			})
			const items = listRes.errCode == 0 ? listRes.data.list.map((item) => {
				return {
					image: item.cover || '/static/zy/route-island.jpg',
					title: item.title || '',
					desc: item.description || item.subtitle || '',
					url: '/pages/service/detail',
					tab: false
				}
			}) : []
			sections.push({
				shortTitle: category.name || '',
				title: category.name || '',
				subtitle: category.type || '',
				icon: category.icon || '服',
				color: '#1677FF',
				helperBg: '#edf5ff',
				helperTitle: (category.name || '') + '咨询',
				helperDesc: '项目咨询 · 预约提交 · 联系方式',
				actionText: '立即咨询',
				actionUrl: '/pages/service/detail',
				actionTab: false,
				items
			})
		}
		serviceSections.value = sections
	} catch (e) {
	}
}

function selectCategory(idx: number) {
	activeCategory.value = idx
}

function openRoute(url: string, tab: boolean) {
	if (tab) {
		uni.switchTab({ url })
	} else {
		uni.navigateTo({ url })
	}
}

</script>

