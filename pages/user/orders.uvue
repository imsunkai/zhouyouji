<template>
	<view class="page">
		<view class="tab-row">
			<text class="tab" :class="status == '' ? 'active-tab' : ''" @tap="switchStatus('')">全部</text>
			<text class="tab" :class="status == 'pending_pay' ? 'active-tab' : ''" @tap="switchStatus('pending_pay')">待付款</text>
			<text class="tab" :class="status == 'pending_send' ? 'active-tab' : ''" @tap="switchStatus('pending_send')">待发货</text>
			<text class="tab" :class="status == 'pending_receive' ? 'active-tab' : ''" @tap="switchStatus('pending_receive')">待收货</text>
			<text class="tab" :class="status == 'after_sale' ? 'active-tab' : ''" @tap="switchStatus('after_sale')">售后</text>
		</view>
		<view class="order-card" v-for="(item, idx) in orders" :key="idx">
			<view class="order-head">
				<text class="order-no">{{item.no}}</text>
				<text class="order-status">{{item.status}}</text>
			</view>
			<view class="goods-row">
				<image class="goods-image" :src="item.image" mode="aspectFill" />
				<view class="goods-copy">
					<text class="goods-title">{{item.title}}</text>
					<text class="goods-desc">{{item.desc}}</text>
					<text class="goods-price">¥{{item.price}}</text>
				</view>
			</view>
			<view class="order-bottom">
				<text class="total">合计 ¥{{item.price}}</text>
				<view class="primary-btn" @tap="detail(item._id)">
					<text class="btn-text">查看详情</text>
				</view>
			</view>
		</view>
		<view v-if="orders.length == 0" class="empty">
			<text class="empty-title">暂无订单</text>
			<text class="empty-desc">下单后会在这里看到状态和进度</text>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref } from 'vue'
import { createCloudObject } from '/utils/cloud-object.js'
import { onLoad } from '@dcloudio/uni-app'

const userObj = createCloudObject('user')
const orders = ref([])
const status = ref('')

onLoad((query) => {
	status.value = query.status || ''
	loadOrders()
})

function getAnonymousId(): string {
	let id = uni.getStorageSync('zy_anonymous_id') as string
	if (id.length == 0) {
		id = String(Date.now()) + String(Math.floor(Math.random() * 1000000))
		uni.setStorageSync('zy_anonymous_id', id)
	}
	return id
}

async function loadOrders() {
	try {
		const res = await userObj.getOrders({ anonymousId: getAnonymousId(), status: status.value })
		if (res.errCode == 0) orders.value = res.data.list || []
	} catch (e) {
		uni.showToast({ title: '订单加载失败', icon: 'none' })
	}
}

function switchStatus(value: string) {
	status.value = value
	loadOrders()
}

function detail(id: string) {
	if (!id) {
		uni.showToast({ title: '订单信息缺失', icon: 'none' })
		return
	}
	uni.navigateTo({
		url: '/pages/order/detail?id=' + id
	})
}
</script>

<style>
