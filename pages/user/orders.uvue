	min-height: 100vh;
	padding: 24rpx 30rpx 40rpx;
	background: #f5f7fa;
}

.tab-row {
	padding: 0 4rpx 22rpx;
	display: flex;
	flex-direction: row;
	justify-content: space-between;
}

.tab {
	color: #667085;
	font-size: 24rpx;
}

.active-tab {
	color: #1677ff;
	font-weight: 900;
}

.order-card {
	margin-bottom: 22rpx;
	padding: 26rpx;
	border-radius: 22rpx;
	background: #ffffff;
	box-shadow: 0 10rpx 26rpx rgba(30,48,84,0.06);
}

.order-head,
.goods-row,
.order-bottom {
	display: flex;
	flex-direction: row;
	align-items: center;
}

.order-no {
	color: #667085;
	font-size: 22rpx;
}

.order-status {
	margin-left: auto;
	color: #1677ff;
	font-size: 23rpx;
	font-weight: 800;
}

.goods-row {
	margin-top: 22rpx;
}

.goods-image {
	width: 150rpx;
	height: 116rpx;
	border-radius: 14rpx;
	background: #edf2f8;
}

.goods-copy {
	flex: 1;
	min-width: 0;
	margin-left: 18rpx;
	display: flex;
	flex-direction: column;
}

.goods-title {
	color: #111827;
	font-size: 26rpx;
	font-weight: 800;
}

.goods-desc {
	margin-top: 8rpx;
	color: #7c8797;
	font-size: 21rpx;
}

.goods-price {
	margin-top: 12rpx;
	color: #ff3b30;
	font-size: 27rpx;
	font-weight: 900;
}

.order-bottom {
	margin-top: 24rpx;
	justify-content: flex-end;
}

.total {
	color: #344054;
	font-size: 23rpx;
	font-weight: 800;
}

.primary-btn {
	width: 150rpx;
	height: 52rpx;
	min-height: 0;
	box-sizing: border-box;
	margin-left: 18rpx;
	border-radius: 999rpx;
	background: #1677ff;
	color: #ffffff;
	font-size: 21rpx;
	font-weight: 800;
	display: flex;
	flex-direction: row;
	align-items: center;
	justify-content: center;
	line-height: 1;
	padding: 0;
	flex: 0 0 150rpx;
	overflow: hidden;
}

.empty {
	margin-top: 120rpx;
	display: flex;
	flex-direction: column;
	align-items: center;
}

.empty-title {
	color: #07152d;
	font-size: 30rpx;
	font-weight: 900;
}

.empty-desc {
	margin-top: 12rpx;
	color: #98a2b3;
	font-size: 23rpx;
}
</style>
