.logged-page{height:100vh;background:#f5f7fa}.profile-hero{position:relative;height:388rpx;overflow:hidden}.profile-bg{position:absolute;left:0;top:0;width:100%;height:388rpx}.custom-title{position:absolute;left:0;right:0;top:88rpx;display:flex;align-items:center;justify-content:center}.title-text{color:#07152d;font-size:34rpx;font-weight:900}.profile-main{position:absolute;left:30rpx;right:30rpx;bottom:42rpx;display:flex;flex-direction:row;align-items:center}.avatar{width:132rpx;height:132rpx;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 12rpx 28rpx rgba(22,119,255,.14);overflow:hidden}.avatar-logo{width:92rpx;height:92rpx;border-radius:50%}.profile-copy{margin-left:26rpx;display:flex;flex-direction:column}.nickname{color:#07152d;font-size:36rpx;font-weight:900}.member-badge{margin-top:20rpx;align-self:flex-start;height:44rpx;padding:0 20rpx;border-radius:999rpx;background:rgba(255,255,255,.78);display:flex;flex-direction:row;align-items:center}.member-icon{color:#1f78ff;font-size:20rpx;margin-right:10rpx}.member-text{color:#26456d;font-size:22rpx;font-weight:800}.member-arrow{margin-left:10rpx;color:#26456d;font-size:28rpx}.home-link{margin-left:auto;padding:14rpx 22rpx;border-radius:999rpx;background:rgba(255,255,255,.72)}.home-link-text{color:#193b69;font-size:24rpx;font-weight:700}.card{margin:0 30rpx 24rpx;padding:28rpx;border-radius:18rpx;background:#fff;box-shadow:0 12rpx 28rpx rgba(30,48,84,.06)}.order-card{margin-top:-6rpx}.section-head{display:flex;flex-direction:row;align-items:center;justify-content:space-between}.section-title{color:#07152d;font-size:30rpx;font-weight:900}.section-more{color:#8a93a6;font-size:23rpx}.order-grid{margin-top:32rpx;display:flex;flex-direction:row;justify-content:space-between}.order-item{width:118rpx;display:flex;flex-direction:column;align-items:center}.order-icon-wrap{position:relative;width:74rpx;height:64rpx;display:flex;align-items:center;justify-content:center}.o