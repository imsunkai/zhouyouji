<template>
	<view class="page">
		<view v-if="!logged" class="login-page">
			<image class="hero-bg" src="/static/zy/splash-login.jpg" mode="aspectFill" />
			<view class="hero-mask"></view>
			<view class="brand">
				<image class="brand-logo" src="/static/zy/logo-mark.png" mode="aspectFit" />
				<text class="brand-title">舟游记</text>
				<text class="brand-en">ZHOUYOUJI</text>
				<text class="brand-slogan">连接舟山本地好服务</text>
			</view>
			<view class="login-panel">
				<text class="panel-title">欢迎登录舟游记</text>
				<view class="title-line">
					<view class="line-main"></view>
					<view class="line-dot"></view>
				</view>
				<text class="panel-desc">一键登录，开启您的舟山之旅</text>
				<view class="wechat-btn" @tap="login">
					<view class="wechat-mark">
						<view class="bubble bubble-a"></view>
						<view class="bubble bubble-b"></view>
					</view>
					<text class="wechat-text">{{ loading ? '登录中...' : '微信一键登录' }}</text>
				</view>
					<view class="agreement">
						<view class="shield" :class="agreed ? 'checked-shield' : ''" @tap="toggleAgreement"><text class="shield-text">{{ agreed ? '✓' : '' }}</text></view>
						<text class="agree-text">登录即表示同意</text>
						<text class="agree-link" @tap="openProtocol">《用户服务协议》</text>
						<text class="agree-text">和</text>
						<text class="agree-link" @tap="openPrivacy">《隐私政策》</text>
					</view>
				<view class="island-art">
					<view class="lighthouse">
						<view class="light-top"></view>
						<view class="light-body"></view>
						<view class="light-base"></view>
					</view>
					<view class="mountain mountain-a"></view>
					<view class="mountain mountain-b"></view>
					<view class="mountain mountain-c"></view>
					<view class="boat boat-a"></view>
					<view class="boat boat-b"></view>
				</view>
				<view class="service" @tap="openPage('/pages/user/support')">
					<text class="service-icon">☎</text>
					<text class="service-text">遇到问题？联系客服</text>
				</view>
			</view>
		</view>

		<scroll-view v-else class="logged-page" scroll-y="true">
			<view class="profile-hero">
				<image class="profile-bg" src="/static/zy/sea-hero.jpg" mode="aspectFill" />
				<view class="custom-title"><text class="title-text">我的</text></view>
				<view class="profile-main">
					<view class="avatar">
						<image class="avatar-logo" :src="userAvatar" mode="aspectFit" />
					</view>
					<view class="profile-copy">
						<text class="nickname">{{ userName }}</text>
						<view class="member-badge">
							<text class="member-icon">♛</text>
							<text class="member-text">普通会员</text>
							<text class="member-arrow">›</text>
						</view>
					</view>
					<view class="home-link" @tap="openPage('/pages/user/profile')">
						<text class="home-link-text">编辑资料 ›</text>
					</view>
				</view>
			</view>

			<view class="card order-card">
				<view class="section-head" @tap="openOrders('')">
					<text class="section-title">我的订单</text>
					<text class="section-more">全部订单 ›</text>
				</view>
				<view class="order-grid">
					<view class="order-item" v-for="(item, idx) in orderItems" :key="idx" @tap="openOrders(item.status)">
						<view class="order-icon-wrap">
							<text class="order-icon">{{ item.icon }}</text>
							<text v-if="item.count > 0" class="count-badge">{{ item.count }}</text>
						</view>
						<text class="order-label">{{ item.label }}</text>
					</view>
				</view>
			</view>

			<view class="card">
				<view class="section-head">
					<text class="section-title">常用功能</text>
				</view>
				<view class="function-grid">
					<view class="function-item" v-for="(item, idx) in functionItems" :key="idx" @tap="openPage(item.url)">
						<view class="function-icon-wrap" :style="'background:' + item.bg">
							<text class="function-icon" :style="'color:' + item.color">{{ item.icon }}</text>
						</view>
						<text class="function-label">{{ item.label }}</text>
						<text v-if="item.count > 0" class="function-count">{{ item.count }}</text>
					</view>
				</view>
			</view>

			<view class="butler-card">
				<view class="butler-copy">
					<text class="butler-title">专属管家服务</text>
					<text class="butler-desc">一对一服务，让舟山之旅更省心</text>
					<view class="butler-btn" @tap="openPage('/pages/user/support')">
						<text class="butler-btn-text">立即联系</text>
					</view>
				</view>
				<image class="butler-image" src="/static/zy/butler.jpg" mode="aspectFit" />
			</view>

			<view class="logout-btn" @tap="logout">
				<text class="logout-text">退出登录</text>
			</view>
		</scroll-view>
	</view>
</template>

<script setup lang="uts">
import { ref } from 'vue'
import { createCloudObject } from '/utils/cloud-object.js'
import { onShow } from '@dcloudio/uni-app'

const userObj = createCloudObject('user')
const logged = ref(false)
const loading = ref(false)
const agreed = ref(false)
const userName = ref('舟游记用户')
const userAvatar = ref('/static/logo.png')

const orderItems = ref([
	{ label: '待付款', icon: '付', status: 'pending_pay', count: 0 },
	{ label: '待服务', icon: '服', status: 'pending_send', count: 0 },
	{ label: '待评价', icon: '评', status: 'pending_comment', count: 0 },
	{ label: '售后/退款', icon: '退', status: 'after_sale', count: 0 }
])

const functionItems = ref([
	{ label: '我的发布', icon: '✎', url: '/pages/activity/activity', color: '#1677ff', bg: '#eaf3ff', count: 0 },
	{ label: '我的收藏', icon: '♥', url: '/pages/user/favorites', color: '#ff3b30', bg: '#fff3f1', count: 0 },
	{ label: '联系客服', icon: '☎', url: '/pages/user/support', color: '#1677ff', bg: '#eaf3ff', count: 0 },
	{ label: '意见反馈', icon: '▤', url: '/pages/user/feedback', color: '#8b5cf6', bg: '#f3efff', count: 0 },
	{ label: '关于我们', icon: 'i', url: '/pages/user/about', color: '#ff9800', bg: '#fff7e8', count: 0 },
	{ label: '设置', icon: '⚙', url: '/pages/user/settings', color: '#1677ff', bg: '#eaf3ff', count: 0 }
])

onShow(() => {
	loadUser()
})

function getAnonymousId(): string {
	let id = uni.getStorageSync('zy_anonymous_id') as string
	if (id.length == 0) {
		id = String(Date.now()) + String(Math.floor(Math.random() * 1000000))
		uni.setStorageSync('zy_anonymous_id', id)
	}
	return id
}

function anonymousParams() {
	return { anonymousId: getAnonymousId() }
}

function applyUser(user) {
	userName.value = user.nickname || '舟游记用户'
	userAvatar.value = user.avatar || '/static/logo.png'
}

function loadLocalUser(): boolean {
	const ready = uni.getStorageSync('zy_user_login_ready')
	const user = uni.getStorageSync('zy_user_info')
	if (ready != '1' || !user) {
		logged.value = false
		return false
	}
	logged.value = true
	applyUser(user)
	return true
}

async function loadUser() {
	if (!loadLocalUser()) return
	try {
		const res = await userObj.getMyCenter(anonymousParams())
		if (res.errCode != 0) return
		uni.setStorageSync('zy_user_info', res.data.user)
		applyUser(res.data.user)
		applyCenter(res.data.orderCounts, res.data.serviceCounts)
	} catch (e) {
		console.log('getMyCenter failed', e)
	}
}

function applyCenter(orderCounts, serviceCounts) {
	orderItems.value = [
		{ label: '待付款', icon: '付', status: 'pending_pay', count: orderCounts.pendingPay || 0 },
		{ label: '待服务', icon: '服', status: 'pending_send', count: (orderCounts.pendingSend || 0) + (orderCounts.pendingReceive || 0) },
		{ label: '待评价', icon: '评', status: 'pending_comment', count: orderCounts.pendingComment || 0 },
		{ label: '售后/退款', icon: '退', status: 'after_sale', count: orderCounts.afterSale || 0 }
	]
	const counts = serviceCounts || {}
	functionItems.value = [
		{ label: '我的发布', icon: '✎', url: '/pages/activity/activity', color: '#1677ff', bg: '#eaf3ff', count: 0 },
		{ label: '我的收藏', icon: '♥', url: '/pages/user/favorites', color: '#ff3b30', bg: '#fff3f1', count: counts.favorites || 0 },
		{ label: '联系客服', icon: '☎', url: '/pages/user/support', color: '#1677ff', bg: '#eaf3ff', count: 0 },
		{ label: '意见反馈', icon: '▤', url: '/pages/user/feedback', color: '#8b5cf6', bg: '#f3efff', count: 0 },
		{ label: '关于我们', icon: 'i', url: '/pages/user/about', color: '#ff9800', bg: '#fff7e8', count: 0 },
		{ label: '设置', icon: '⚙', url: '/pages/user/settings', color: '#1677ff', bg: '#eaf3ff', count: 0 }
	]
}

function needProfile(user): boolean {
	return !user || !user.nickname || user.nickname == '舟游记用户' || !user.avatar
}

async function login() {
	if (loading.value) return
	if (!agreed.value) {
		uni.showToast({ title: '请先勾选并同意协议', icon: 'none' })
		return
	}
	loading.value = true
	uni.showLoading({ title: '登录中' })
	try {
		const res = await userObj.wxLogin({
			anonymousId: getAnonymousId()
		})
		uni.hideLoading()
		if (res.errCode != 0) {
			uni.showToast({ title: res.errMsg || '登录失败', icon: 'none' })
			return
		}
		uni.setStorageSync('zy_user_info', res.data.user)
		uni.setStorageSync('zy_user_login_ready', '1')
		await loadUser()
		if (needProfile(res.data.user)) {
			uni.showToast({ title: '请完善头像昵称', icon: 'none' })
			setTimeout(() => {
				uni.navigateTo({ url: '/pages/user/profile' })
			}, 350)
		} else {
			uni.hideToast()
		}
	} catch (e) {
		uni.hideLoading()
		uni.showModal({
			title: '登录失败',
			content: '请确认微信云开发环境已开通，api 云函数已上传部署，数据库集合已创建',
			showCancel: false
		})
	} finally {
		loading.value = false
	}
}

function logout() {
	uni.removeStorageSync('zy_user_info')
	uni.removeStorageSync('zy_user_login_ready')
	logged.value = false
}

function toggleAgreement() {
	agreed.value = !agreed.value
}

function openProtocol() {
	uni.showModal({
		title: '用户服务协议',
		content: '欢迎使用舟游记。您登录后可使用平台提供的本地服务、订单、发布和个人中心等功能。请您保证提交信息真实有效，并遵守平台服务规则。',
		showCancel: false,
		confirmText: '我知道了'
	})
}

function openPrivacy() {
	uni.showModal({
		title: '隐私政策',
		content: '舟游记仅在提供登录、订单、地址、反馈等功能时使用必要信息。您的头像、昵称和收货信息仅用于小程序服务展示与履约，我们不会超出服务目的使用。',
		showCancel: false,
		confirmText: '我知道了'
	})
}

function openOrders(status: string) {
	uni.navigateTo({ url: '/pages/user/orders?status=' + status })
}

function openPage(url: string) {
	if (url.indexOf('/pages/index/index') == 0 || url.indexOf('/pages/service/service') == 0 || url.indexOf('/pages/activity/activity') == 0 || url.indexOf('/pages/user/user') == 0) {
		uni.switchTab({ url })
		return
	}
	uni.navigateTo({ url })
}
</script>

<style>
