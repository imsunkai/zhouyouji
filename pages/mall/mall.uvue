<script setup lang="uts">
import { ref } from 'vue'

const cartCount = ref(0)
const cartTotal = ref(0)

// TODO: 商城接口建议拆为 banner、分类、营销位、商品列表和购物车摘要。
const categories = ref([
	{ title: '海鲜水产', image: '/static/zy/crab.jpg' },
	{ title: '食品特产', image: '/static/zy/fish.jpg' },
	{ title: '文创精品', image: '/static/zy/mall-hero.jpg' },
	{ title: '礼盒专区', image: '/static/zy/abalone.jpg' },
	{ title: '全部分类', image: '/static/zy/mall-hero.jpg' }
])

const guarantees = ref([
	{ icon: '验', title: '品质保证', desc: '严格品控 放心选购' },
	{ icon: '产', title: '产地直供', desc: '源头直供 新鲜到家' },
	{ icon: '冷', title: '冷链配送', desc: '全程冷链 锁住鲜度' },
	{ icon: '售', title: '售后无忧', desc: '7天无理由退换' }
])

const flashProducts = ref([
	{ image: '/static/zy/fish.jpg', name: '舟山带鱼段', price: 59.9 },
	{ image: '/static/zy/abalone.jpg', name: '野生大黄鱼', price: 69.9 },
	{ image: '/static/zy/snail.jpg', name: '舟山小鲍鱼', price: 39.9 }
])

const products = ref([
	{ image: '/static/zy/crab.jpg', labelA: '新鲜捕捞', labelB: '顺丰包邮', name: '舟山梭子蟹（鲜活）', desc: '膏肥肉满 鲜活直达', price: 138, sold: 1286 },
	{ image: '/static/zy/shrimp.jpg', labelA: '冷链配送', labelB: '坏单包赔', name: '舟山野生大虾', desc: '肉质紧实 营养美味', price: 168, sold: 856 },
	{ image: '/static/zy/abalone.jpg', labelA: '顺丰包邮', labelB: '源头直供', name: '舟山活鲍鱼', desc: '鲜活捕捞 个大肥美', price: 68, sold: 632 },
	{ image: '/static/zy/fish.jpg', labelA: '新鲜捕捞', labelB: '本地好物', name: '舟山大黄鱼', desc: '鲜嫩美味 肉质细腻', price: 69.9, sold: 742 },
	{ image: '/static/zy/squid.jpg', labelA: '冷链配送', labelB: '新鲜直达', name: '舟山鲜鱿鱼', desc: '口感脆嫩 新鲜直达', price: 48, sold: 512 },
	{ image: '/static/zy/snail.jpg', labelA: '顺丰包邮', labelB: '满减好价', name: '舟山花蛤', desc: '鲜活无沙 肉质鲜美', price: 28, sold: 398 }
])

function addCart(name: string, price: number) {
	cartCount.value = cartCount.value + 1
	cartTotal.value = cartTotal.value + price
	uni.showToast({
		title: name + '已加入购物车',
		icon: 'none'
	})
}

function goCategory() {
	uni.navigateTo({
		url: '/pages/category/category'
	})
}

function goProductDetail() {
	uni.navigateTo({
		url: '/pages/mall/detail'
	})
}

function showComing(name: string) {
	uni.showToast({
		title: name + '功能即将上线',
		icon: 'none'
	})
}
</script>

