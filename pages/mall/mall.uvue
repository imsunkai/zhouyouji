		</view>

		<view class="category-row">
			<view class="category-item" v-for="(item, idx) in categories" :key="idx" @tap="goCategory">
				<image class="category-image" :src="item.image" mode="aspectFill" />
				<text :class="idx == 0 ? 'category-title active-title' : 'category-title'">{{item.title}}</text>
				<view v-if="idx == 0" class="category-line"></view>
			</view>
		</view>

		<view class="guarantee-row">
			<view class="guarantee-item" v-for="(item, idx) in guarantees" :key="idx">
