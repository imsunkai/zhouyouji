						<text class="product-price">¥{{item.price}}</text>
						<text class="sold">已售 {{item.sold}}</text>
						<view class="cart-btn" @tap.stop="addCart(item.name, item.price)">
							<text class="btn-text">+</text>
						</view>
					</view>
				</view>
			</view>
		</view>

		<view class="float-cart" @tap="goCategory">
			<text class="cart-icon">🛒</text>
			<text class="cart-price">¥{{cartTotal}}</text>
			<view v-if="cartCount > 0" class="cart-badge">
				<text class="cart-badge-text">{{cartCount}}</text>
			</view>
