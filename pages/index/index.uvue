					<view class="advantage-icon">
						<text class="advantage-emoji">{{item.icon}}</text>
					</view>
					<text class="advantage-title">{{item.title}}</text>
					<text class="advantage-desc">{{item.desc}}</text>
				</view>
			</view>
		</view>

		<view class="card recommend-card">
			<view class="section-head">
				<text class="section-title">精选推荐</text>
				<text class="section-more" @tap="openRoute('/pages/service/service', true)">查看更多 ›</text>
			</view>
			<scroll-view scroll-x class="recommend-scroll" show-scrollbar="false">
				<view class="recommend-row">
					<view
						class="recommend-item"
						v-for="(item, idx) in recommends"
						:key="idx"
						@tap="openRoute('/pages/service/detail', false)"
					>
						<image class="recommend-image" :src="item.image" mode="aspectFill" />
						<view class="recommend-info">
							<text class="recommend-title">{{item.title}}</text>
							<text class="recommend-desc">{{item.desc}}</text>
							<view class="recommend-bottom">
								<text class="recommend-price">¥{{item.price}}</text>
								<text class="recommend-unit">{{item.unit}}</text>
								<text class="recommend-tag">{{item.tag}}</text>
							</view>
						</view>
					</view>
				</view>
			</scroll-view>
		</view>

		<view class="consult-card">
			<view class="consult-icon">
				<text class="consult-emoji">☎</text>
			</view>
			<view class="consult-copy">
