<template>
	<view class="page">
		<view class="hero">
			<image class="hero-image" src="/static/zy/sea-hero.jpg" mode="aspectFill" />
			<view class="hero-mask"></view>
			<view class="hero-copy">
				<text class="hero-title">舟游记</text>
				<text class="hero-subtitle">舟山本地资源服务平台</text>
				<text class="hero-tags">旅游 · 车务 · 住宿 · 特产 · 二手车</text>
				<view class="hero-line">
					<view class="line-long"></view>
					<view class="line-short"></view>
				</view>
			</view>
		</view>

		<view class="quick-card">
			<view
				class="quick-item"
				v-for="(item, idx) in serviceEntrances"
				:key="idx"
				@tap="openRoute(item.url, item.tab)"
			>
				<view class="quick-icon" :style="'background:' + item.color">
					<text class="quick-emoji">{{item.icon}}</text>
				</view>
				<text class="quick-title">{{item.title}}</text>
				<text class="quick-desc">{{item.desc}}</text>
			</view>
		</view>

