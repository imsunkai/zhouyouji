				<text class="consult-desc">专业顾问为您提供一对一服务</text>
			</view>
			<view class="consult-btn" @tap="consult">
				<text class="btn-text">立即咨询</text>
			</view>
		</view>

		<view class="notice-card" @tap="openRoute('/pages/user/about', false)">
			<text class="notice-icon">公告</text>
			<text class="notice-text">欢迎使用舟游记小程序，我们将竭诚为您服务！</text>
			<text class="notice-arrow">›</text>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref } from 'vue'
import { createCloudObject } from '/utils/cloud-object.js'
import { onLoad } from '@dcloudio/uni-app'

const serviceObj = createCloudObject('service')

// TODO: 后续接入首页聚合接口，替换本地 mock 数据。
const serviceEntrances = ref([
	{ title: '游玩', desc: '线路推荐 · 定制游', icon: '岛', color: '#4F8FFF', url: '/pages/service/service', tab: true },
	{ title: '住宿', desc: '酒店 · 民宿 · 公寓', icon: '住', color: '#FA8C16', url: '/pages/service/service', tab: true },
	{ title: '服务', desc: '车服 · 特产 · 本地资源', icon: '服', color: '#48B982', url: '/pages/service/service', tab: true },
	{ title: '山海会', desc: '活动 · 交流 · 同城', icon: '会', color: '#8E62E8', url: '/pages/activity/activity', tab: true }
])

const advantages = ref([
	{ title: '本地资源', desc: '深耕舟山\n资源丰富', icon: '⌖' },
	{ title: '靠谱服务', desc: '严选合作\n品质保障', icon: '✓' },
	{ title: '专属客服', desc: '一对一服务\n快速响应', icon: '☎' },
	{ title: '价格透明', desc: '明码标价\n无隐形消费', icon: '赞' }
])

const recommends = ref([
	{ image: '/static/zy/tour-lighthouse.jpg', title: '朱家尖一日游', desc: '经典海岛路线', price: '198', unit: '起/人', tag: '热门' },
	{ image: '/static/zy/car-coast.jpg', title: '普陀山接送服务', desc: '机场/码头接送', price: '180', unit: '起/次', tag: '便捷' },
	{ image: '/static/zy/hotel-seaview.jpg', title: '海景民宿推荐', desc: '优质海景房源', price: '268', unit: '起/晚', tag: '优选' },
	{ image: '/static/zy/crab.jpg', title: '舟山海鲜礼盒', desc: '新鲜美味 · 顺丰包邮', price: '268', unit: '起', tag: '好物' }
])

onLoad(() => {
	loadHomeRecommend()
})

async function loadHomeRecommend() {
	try {
		const res = await serviceObj.getHomeRecommend({ page: 1, pageSize: 10 })
		if (res.errCode == 0 && res.data.list.length > 0) {
			recommends.value = res.data.list.map((item) => {
				return {
					image: item.cover || '/static/zy/tour-lighthouse.jpg',
					title: item.title || '',
					desc: item.description || item.subtitle || '',
					price: String(item.price || ''),
					unit: item.unit || '',
					tag: item.category_name || ''
				}
			})
		}
	} catch (e) {
	}
}

function openRoute(url: string, tab: boolean) {
	if (tab) {
		uni.switchTab({ url })
	} else {
		uni.navigateTo({ url })
	}
}

function consult() {
	uni.showToast({
		title: '已为您连接专属顾问',
		icon: 'none'
	})
}
</script>

