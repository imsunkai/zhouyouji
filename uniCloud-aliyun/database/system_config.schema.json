{
  "bsonType": "object",
  "required": ["key", "status", "create_time", "update_time"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": { "description": "record id" },
    "key": { "bsonType": "string", "description": "config key" },
    "value": { "bsonType": "object", "description": "config value" },
    "title": { "bsonType": "string", "description": "config title" },
    "description": { "bsonType": "string", "description": "config description" },
    "status": { "bsonType": "int", "description": "1 enabled, 0 disabled" },
    "create_time": { "bsonType": "timestamp", "description": "created timestamp" },
    "update_time": { "bsonType": "timestamp", "description": "updated timestamp" }
  }
}
