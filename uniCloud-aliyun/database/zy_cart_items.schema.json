                                        "description":  "quantity"
                                    },
                       "status":  {
                                      "bsonType":  "int",
                                      "description":  "status"
                                  },
                       "create_time":  {
                                           "bsonType":  "timestamp",
                                           "description":  "create_time"
                                       },
                       "update_time":  {
                                           "bsonType":  "timestamp",
                                           "description":  "update_time"
                                       }
                   }
}
