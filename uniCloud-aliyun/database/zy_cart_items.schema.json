                                   "description":  "id"
                               },
                       "openid":  {
                                      "bsonType":  "string",
                                      "description":  "openid"
                                  },
                       "product_id":  {
                                          "bsonType":  "string",
                                          "description":  "product_id"
                                      },
                       "product_snapshot":  {
                                                "bsonType":  "object",
                                                "description":  "product_snapshot"
                                            },
                       "quantity":  {
